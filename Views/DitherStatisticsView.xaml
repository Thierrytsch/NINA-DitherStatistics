<?xml version="1.0" encoding="utf-8"?>
<UserControl x:Class="DitherStatistics.Plugin.DitherStatisticsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="700" d:DesignWidth="400">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- ============================================================
             Design-system foundations (Step 1)
             One place for the typographic scale, card/tile chrome, the
             experimental badge, the chart tooltip overlay and the profile
             action icons. Everything below references these instead of
             repeating literals.
             ============================================================ -->

        <!-- Typographic scale — exactly four sizes.
             SectionHeader 14 / MetricValue 15 / Body 11 / Caption 10.
             SecondaryTextStyle is Caption + the muted brush, defined once so
             the "secondary text" colour can be changed in a single place. -->
        <Style x:Key="SectionHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>
        <Style x:Key="MetricValueStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>
        <Style x:Key="BodyTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>
        <Style x:Key="CaptionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>
        <Style x:Key="SecondaryTextStyle" TargetType="TextBlock" BasedOn="{StaticResource CaptionTextStyle}">
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundDisabledBrush}"/>
        </Style>

        <!-- Shared card chrome applied to every top-level section Border. -->
        <Style x:Key="SectionCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <!-- Shared metric-tile chrome applied to every value tile. -->
        <Style x:Key="MetricTileStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8"/>
        </Style>

        <!-- Optimizer profile tile: metric-tile chrome, but the recommended (Fast)
             column gets a PrimaryBrush accent border so the user-approved default
             stands out from the neutral Strict/Standard columns. -->
        <Style x:Key="OptimizerProfileTileStyle" TargetType="Border" BasedOn="{StaticResource MetricTileStyle}">
            <Setter Property="Margin" Value="0,0,4,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecommended}" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Optimizer "P## / tagline" subheader: muted, but emphasized on the
             recommended column so the "recommended" tag reads at a glance. -->
        <Style x:Key="OptimizerTaglineStyle" TargetType="TextBlock" BasedOn="{StaticResource SecondaryTextStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsRecommended}" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- One value line inside an optimizer tile: big bold value + muted unit.
             Bound to an OptimizerProfileDisplay; the value/unit are supplied via Tag
             on the host so the three (Settle Pixel / Expected Settle / Timeout) lines
             reuse this shape. -->
        <Style x:Key="OptimizerUnitRunStyle" TargetType="Run">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundDisabledBrush}"/>
        </Style>
        <Style x:Key="OptimizerValueRunStyle" TargetType="Run">
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
        </Style>

        <!-- Shared DataTemplate for one optimizer profile column. Replaces the three
             copy-pasted Strict/Standard/Fast blocks; bound to OptimizerProfileDisplay. -->
        <DataTemplate x:Key="OptimizerProfileTemplate">
            <Border Style="{StaticResource OptimizerProfileTileStyle}"
                    ToolTip="{Binding ToolTip}">
                <StackPanel>
                    <!-- Profile header -->
                    <TextBlock Text="{Binding Name}"
                              Style="{StaticResource BodyTextStyle}"
                              FontWeight="Bold"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,2"/>
                    <TextBlock Style="{StaticResource OptimizerTaglineStyle}"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,8">
                        <Run Text="{Binding Quantile, Mode=OneWay}"/><Run Text="  /  "/><Run Text="{Binding Tagline, Mode=OneWay}"/>
                    </TextBlock>

                    <!-- Settle tolerance -->
                    <TextBlock Text="Settle Pixel"
                              Style="{StaticResource SecondaryTextStyle}"
                              HorizontalAlignment="Center"
                              ToolTip="Distance from lock position PHD2 waits for after a dither (guide camera pixels)"/>
                    <TextBlock HorizontalAlignment="Center">
                        <Run Text="{Binding SettlePixel, Mode=OneWay}" Style="{StaticResource OptimizerValueRunStyle}"/><Run Text=" px" Style="{StaticResource OptimizerUnitRunStyle}"/>
                    </TextBlock>
                    <TextBlock Text="{Binding Arcsec, Mode=OneWay}"
                              Style="{StaticResource SecondaryTextStyle}"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,6"/>

                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Margin="4,0,4,6"/>

                    <!-- Expected settle duration -->
                    <TextBlock Text="Expected Settle"
                              Style="{StaticResource SecondaryTextStyle}"
                              HorizontalAlignment="Center"
                              ToolTip="Median time from dither until guiding stayed below this tolerance — for information, do NOT enter as min settle time"/>
                    <TextBlock HorizontalAlignment="Center" Margin="0,0,0,6">
                        <Run Text="{Binding ExpectedSettle, Mode=OneWay}" Style="{StaticResource OptimizerValueRunStyle}"/><Run Text=" s" Style="{StaticResource OptimizerUnitRunStyle}"/>
                    </TextBlock>

                    <Border BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0"
                            Margin="4,0,4,6"/>

                    <!-- Settle timeout -->
                    <TextBlock Text="Settle Timeout"
                              Style="{StaticResource SecondaryTextStyle}"
                              HorizontalAlignment="Center"
                              ToolTip="Suggested settle timeout: covers 95% of observed settle delays plus margin"/>
                    <TextBlock HorizontalAlignment="Center">
                        <Run Text="{Binding Timeout, Mode=OneWay}" Style="{StaticResource OptimizerValueRunStyle}"/><Run Text=" s" Style="{StaticResource OptimizerUnitRunStyle}"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- Shared DataTemplate for the Quality / Optimizer "disabled or not enough
             data" info box. Bound to a SectionStatusDisplay so both sections render
             from one layout (title + resolved message + enable toggle). -->
        <DataTemplate x:Key="SectionStatusCardTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="{Binding Title}"
                              Style="{StaticResource SectionHeaderStyle}"
                              HorizontalAlignment="Center"
                              Margin="0,0,0,4"/>
                    <TextBlock Text="{Binding Message}"
                              Style="{StaticResource SecondaryTextStyle}"
                              HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- DynamicResource on purpose: ToggleSwitchStyle is defined further
                     down in this dictionary, and StaticResource inside deferred
                     template content only sees keys defined before the template —
                     resolving it statically throws XamlParseException when the
                     info box first becomes visible. -->
                <CheckBox Grid.Column="1"
                         IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                         HorizontalAlignment="Right"
                         VerticalAlignment="Top"
                         Margin="0,0,5,0"
                         ToolTip="{Binding Title, StringFormat='Enable / Disable {0}'}"
                         Style="{DynamicResource ToggleSwitchStyle}"/>
            </Grid>
        </DataTemplate>

        <!-- Overall-rating chip palette. Moved out of the VM's QualityRatingColor
             switch so the semantic green→red scale lives next to the rest of the
             design-system resources (Step 5). RatingBadgeStyle picks a brush via a
             DataTrigger on QualityResult.QualityRating; the white chip text keeps
             the same encoding on every theme (the chip background is a fixed colour,
             not a theme brush, so contrast doesn't shift with the theme). -->
        <SolidColorBrush x:Key="RatingExcellentBrush" Color="#4CAF50"/>
        <SolidColorBrush x:Key="RatingVeryGoodBrush" Color="#66BB6A"/>
        <SolidColorBrush x:Key="RatingGoodBrush" Color="#8BC34A"/>
        <SolidColorBrush x:Key="RatingAcceptableBrush" Color="#FFC107"/>
        <SolidColorBrush x:Key="RatingFairBrush" Color="#FF9800"/>
        <SolidColorBrush x:Key="RatingPoorBrush" Color="#F44336"/>
        <SolidColorBrush x:Key="RatingNeutralBrush" Color="#9E9E9E"/>

        <Style x:Key="RatingBadgeStyle" TargetType="Border">
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Background" Value="{StaticResource RatingNeutralBrush}"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding QualityResult.QualityRating}" Value="Excellent">
                    <Setter Property="Background" Value="{StaticResource RatingExcellentBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding QualityResult.QualityRating}" Value="Very Good">
                    <Setter Property="Background" Value="{StaticResource RatingVeryGoodBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding QualityResult.QualityRating}" Value="Good">
                    <Setter Property="Background" Value="{StaticResource RatingGoodBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding QualityResult.QualityRating}" Value="Acceptable">
                    <Setter Property="Background" Value="{StaticResource RatingAcceptableBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding QualityResult.QualityRating}" Value="Fair">
                    <Setter Property="Background" Value="{StaticResource RatingFairBrush}"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding QualityResult.QualityRating}" Value="Poor">
                    <Setter Property="Background" Value="{StaticResource RatingPoorBrush}"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- EXPERIMENTAL badge: neutral outline chip. Red would read as an
             error state, which is not what "experimental" means. -->
        <Style x:Key="ExperimentalBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- Chart tooltip overlay: one shared accent (PrimaryBrush) for both
             charts instead of two different hardcoded blues. Visibility stays
             per-chart on each instance. -->
        <Style x:Key="TooltipOverlayStyle" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Opacity" Value="0.95"/>
        </Style>

        <!-- Self-defined monochrome icon geometries. NINA's SVGDictionary has
             no add/delete keys reachable from a plugin (Step 0), so these are
             local paths rendered in PrimaryBrush — never emojis. -->
        <Geometry x:Key="IconAddGeometry">M13,5 L11,5 L11,11 L5,11 L5,13 L11,13 L11,19 L13,19 L13,13 L19,13 L19,11 L13,11 Z</Geometry>
        <Geometry x:Key="IconDeleteGeometry">M10,4 L14,4 L15,6 L19,6 L19,8 L5,8 L5,6 L9,6 Z M6,9 L18,9 L17,21 L7,21 Z</Geometry>
        <!-- Recalc (circular refresh) and Export (download-to-file) glyphs for the
             Quality-card action buttons. Same local-geometry approach as the profile
             icons, since NINA exposes no reachable refresh/save key (Step 0). -->
        <Geometry x:Key="IconRefreshGeometry">M17.65,6.35 C16.2,4.9 14.21,4 12,4 C7.58,4 4.01,7.58 4.01,12 C4.01,16.42 7.58,20 12,20 C15.73,20 18.84,17.45 19.73,14 L17.65,14 C16.83,16.33 14.61,18 12,18 C8.69,18 6,15.31 6,12 C6,8.69 8.69,6 12,6 C13.66,6 15.14,6.69 16.22,7.78 L13,11 L20,11 L20,4 L17.65,6.35 Z</Geometry>
        <Geometry x:Key="IconExportGeometry">M5,18 L19,18 L19,20 L5,20 Z M9,3 L15,3 L15,9 L19,9 L12,16 L5,9 L9,9 Z</Geometry>

        <!-- NINA StandardCheckBox Style - exact copy from NINA source -->
        <Style x:Key="ToggleSwitchStyle" TargetType="CheckBox">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Width" Value="65" />
            <Setter Property="Height" Value="25" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="CheckBox">
                        <Grid>
                            <!-- Track -->
                            <Border
                                x:Name="SwitchTrack"
                                Background="Transparent"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12.5" />
                            <Grid>
                                <TextBlock
                                    x:Name="OnText"
                                    Margin="8,0,0,0"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource ButtonForegroundBrush}"
                                    Text="ON"
                                    Visibility="Collapsed" />
                                <TextBlock
                                    x:Name="OffText"
                                    Margin="0,0,8,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Foreground="{DynamicResource PrimaryBrush}"
                                    Text="OFF"
                                    Visibility="Visible" />
                            </Grid>
                            <!-- Thumb -->
                            <Ellipse
                                x:Name="SwitchThumb"
                                Width="21"
                                Height="21"
                                Margin="2"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Fill="{DynamicResource SecondaryBackgroundBrush}" />
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Right" />
                                <Setter TargetName="OnText" Property="Visibility" Value="Visible" />
                                <Setter TargetName="OffText" Property="Visibility" Value="Collapsed" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="SwitchTrack" Property="Background" Value="Transparent" />
                                <Setter TargetName="SwitchThumb" Property="HorizontalAlignment" Value="Left" />
                                <Setter TargetName="OnText" Property="Visibility" Value="Collapsed" />
                                <Setter TargetName="OffText" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="SwitchTrack" Property="Opacity" Value="0.4" />
                                <Setter TargetName="SwitchThumb" Property="Opacity" Value="0.4" />
                                <Setter TargetName="OnText" Property="Opacity" Value="0.4" />
                                <Setter TargetName="OffText" Property="Opacity" Value="0.4" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon + text button (Quality-card Recalc / Export Report, Actions toolbar).
             The template hosts a leading Path glyph (geometry via Tag) ahead of the
             text so the actions read at a glance. -->
        <Style x:Key="IconTextButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource ButtonForegroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="12" Height="12"
                                         Margin="0,0,5,0"
                                         VerticalAlignment="Center">
                                    <Path Data="{TemplateBinding Tag}"
                                          Fill="{TemplateBinding Foreground}"/>
                                </Viewbox>
                                <TextBlock Text="{TemplateBinding Content}"
                                          Foreground="{TemplateBinding Foreground}"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonBackgroundSelectedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonBackgroundSelectedBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Icon button for the profile add/delete actions. Hosts a geometry
             (supplied via Tag) in PrimaryBrush instead of a text glyph, so we
             never fall back to emojis. -->
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource ButtonBackgroundBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="25"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <Viewbox>
                                <Path Data="{TemplateBinding Tag}"
                                      Fill="{DynamicResource PrimaryBrush}"/>
                            </Viewbox>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonBackgroundSelectedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{DynamicResource ButtonBackgroundSelectedBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Delete icon button - disabled while Default is selected. -->
        <Style x:Key="DeleteIconButtonStyle" TargetType="Button" BasedOn="{StaticResource IconButtonStyle}">
            <Style.Triggers>
                <DataTrigger Binding="{Binding SelectedProfileName}" Value="Default">
                    <Setter Property="IsEnabled" Value="False"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Minimal dark-theme editable ComboBox (no NINA ComboBox style is reachable from the plugin).
             The PART_EditableTextBox and PART_Popup names are required for editable behavior. -->
        <Style x:Key="ProfileComboBoxStyle" TargetType="ComboBox">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
            <Setter Property="Background" Value="{DynamicResource TertiaryBackgroundBrush}"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                        <Setter Property="Padding" Value="6,3"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="bd" Background="Transparent" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsHighlighted" Value="True">
                                            <Setter TargetName="bd" Property="Background"
                                                    Value="{DynamicResource ButtonBackgroundSelectedBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Setter.Value>
            </Setter>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="border"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="3"/>
                            <ToggleButton Background="Transparent"
                                          BorderThickness="0"
                                          Focusable="False"
                                          HorizontalAlignment="Stretch"
                                          ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="Transparent">
                                            <Path Data="M 0 0 L 4 4 L 8 0 Z"
                                                  Fill="{DynamicResource PrimaryBrush}"
                                                  HorizontalAlignment="Right"
                                                  VerticalAlignment="Center"
                                                  Margin="0,0,8,0"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <TextBox x:Name="PART_EditableTextBox"
                                     Margin="4,0,20,0"
                                     VerticalAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource PrimaryBrush}"
                                     CaretBrush="{DynamicResource PrimaryBrush}"
                                     Focusable="True"
                                     IsReadOnly="{TemplateBinding IsReadOnly}"/>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   StaysOpen="False">
                                <Border MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="200"
                                        Background="{DynamicResource SecondaryBackgroundBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10">

                <!-- Pixel Shift Chart (ScottPlot) with Tooltip Overlay -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Pixel Shift"
                                  Style="{StaticResource SectionHeaderStyle}"
                                  Margin="0,0,0,10"/>

                        <!-- Grid for Chart + Tooltip Overlay -->
                        <Grid Height="300">
                            <!-- ScottPlot WpfPlot Control -->
                            <ContentControl Content="{Binding PixelShiftPlot}"/>

                            <!-- Tooltip Overlay -->
                            <Border Style="{StaticResource TooltipOverlayStyle}"
                                   Visibility="{Binding PixelShiftTooltipVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding PixelShiftTooltipText}"
                                          Style="{StaticResource BodyTextStyle}"
                                          FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <!-- Legend below the chart. Swatch colors mirror
                             ChartColorPalette in Services/ChartRenderers.cs - keep
                             both in sync if a color changes. -->
                        <StackPanel Orientation="Horizontal"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0">
                            <!-- Oldest -> newest gradient swatch -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Rectangle Width="24" Height="10"
                                          VerticalAlignment="Center"
                                          Margin="0,0,4,0">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#640000" Offset="0.0"/>
                                            <GradientStop Color="#DC0000" Offset="1.0"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <TextBlock Text="Oldest → Newest"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Latest point -->
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="10" Height="10"
                                        Fill="#00BFFF"
                                        VerticalAlignment="Center"
                                        Margin="0,0,4,0"/>
                                <TextBlock Text="Latest"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Settle Time Chart (ScottPlot) with Tooltip Overlay -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <TextBlock Text="Settle Time History"
                                  Style="{StaticResource SectionHeaderStyle}"
                                  Margin="0,0,0,10"/>

                        <!-- Grid for Chart + Tooltip Overlay -->
                        <Grid Height="150">
                            <!-- ScottPlot WpfPlot Control -->
                            <ContentControl Content="{Binding SettleTimePlot}"/>

                            <!-- Tooltip Overlay -->
                            <Border Style="{StaticResource TooltipOverlayStyle}"
                                   Visibility="{Binding SettleTimeTooltipVisible, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding SettleTimeTooltipText}"
                                          Style="{StaticResource BodyTextStyle}"
                                          FontWeight="SemiBold"/>
                            </Border>
                        </Grid>

                        <!-- Legend below the chart. Swatch colors mirror
                             ChartColorPalette in Services/ChartRenderers.cs - keep
                             both in sync if a color changes. -->
                        <StackPanel Orientation="Horizontal"
                                   HorizontalAlignment="Center"
                                   Margin="0,8,0,0">
                            <!-- Settle Time (same accent as Pixel Shift's "Latest" marker) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Ellipse Width="10" Height="10"
                                        Fill="#00BFFF"
                                        VerticalAlignment="Center"
                                        Margin="0,0,4,0"/>
                                <TextBlock Text="Settle Time"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- Average + shaded Avg ± StdDev band (one legend entry) -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,15,0">
                                <Rectangle Width="14" Height="10"
                                          VerticalAlignment="Center"
                                          Margin="0,0,4,0">
                                    <Rectangle.Fill>
                                        <SolidColorBrush Color="#FFC107" Opacity="0.5"/>
                                    </Rectangle.Fill>
                                </Rectangle>
                                <TextBlock Text="Avg ± StdDev"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          VerticalAlignment="Center"/>
                            </StackPanel>

                            <!-- P90/P95/P99 optimizer thresholds -->
                            <StackPanel Orientation="Horizontal">
                                <Rectangle Width="14" Height="2"
                                          Fill="#AB47BC"
                                          VerticalAlignment="Center"
                                          Margin="0,0,4,0"/>
                                <TextBlock Text="P90/P95/P99"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          VerticalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- COMPACT Statistics Panel - 2 rows -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel>
                        <Grid Margin="0,0,0,10">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                          Text="Statistics"
                                          Style="{StaticResource SectionHeaderStyle}"
                                          VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                          Text="Keep across sessions"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"/>

                                <CheckBox Grid.Column="2"
                                         IsChecked="{Binding IsStatisticsPersistenceEnabled, Mode=TwoWay}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,5,0"
                                         ToolTip="When enabled, all statistics are saved to disk and restored on the next NINA start, accumulating across sessions"
                                         Style="{StaticResource ToggleSwitchStyle}"/>
                            </Grid>

                            <!-- Statistics profiles: toggle + editable ComboBox + add/delete -->
                            <Grid Grid.Row="1" Margin="0,8,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                          Text="Profiles"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"/>

                                <CheckBox Grid.Column="1"
                                         IsChecked="{Binding IsMultiProfileEnabled, Mode=TwoWay}"
                                         VerticalAlignment="Center"
                                         Margin="0,0,8,0"
                                         ToolTip="Store statistics in separate selectable profiles (e.g. per target or telescope)"
                                         Style="{StaticResource ToggleSwitchStyle}"/>

                                <ComboBox Grid.Column="2"
                                         Style="{StaticResource ProfileComboBoxStyle}"
                                         IsEditable="True"
                                         ItemsSource="{Binding ProfileNames}"
                                         SelectedItem="{Binding SelectedProfileName, Mode=TwoWay}"
                                         Text="{Binding ProfileNameInput, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         VerticalAlignment="Center"
                                         MinWidth="110"
                                         Height="25"
                                         Visibility="{Binding IsMultiProfileEnabled, Converter={StaticResource BoolToVis}}"
                                         ToolTip="Select a profile, or type a new name and press +"/>

                                <Button Grid.Column="3"
                                       Style="{StaticResource IconButtonStyle}"
                                       Tag="{StaticResource IconAddGeometry}"
                                       Command="{Binding CreateProfileCommand}"
                                       Margin="5,0,0,0"
                                       Visibility="{Binding IsMultiProfileEnabled, Converter={StaticResource BoolToVis}}"
                                       ToolTip="Create the profile typed in the box"/>

                                <Button Grid.Column="4"
                                       Style="{StaticResource DeleteIconButtonStyle}"
                                       Tag="{StaticResource IconDeleteGeometry}"
                                       Command="{Binding DeleteProfileCommand}"
                                       Margin="5,0,0,0"
                                       Visibility="{Binding IsMultiProfileEnabled, Converter={StaticResource BoolToVis}}"
                                       ToolTip="Delete the selected profile (Default cannot be deleted)"/>
                            </Grid>
                        </Grid>

                        <!-- Statistics tile row (unified onto the Quality/Optimizer tile
                             language: label / value / caption). Four tiles: Dithers,
                             Success, Median settle, Drift. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Dithers (total) -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource MetricTileStyle}"
                                    Margin="0,0,4,0"
                                    ToolTip="Total number of dither events recorded in this profile">
                                <StackPanel>
                                    <TextBlock Text="Dithers"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding TotalDithers, Mode=OneWay}"
                                              Style="{StaticResource MetricValueStyle}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="total"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Success (rate + "n of m") -->
                            <Border Grid.Column="1"
                                    Style="{StaticResource MetricTileStyle}"
                                    Margin="0,0,4,0"
                                    ToolTip="Share of dithers that completed successfully (excludes failed / star-lost dithers)">
                                <StackPanel>
                                    <TextBlock Text="Success"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding SuccessRate, StringFormat='{}{0:F1}%', Mode=OneWay}"
                                              Style="{StaticResource MetricValueStyle}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,2,0,0">
                                        <Run Text="{Binding SuccessfulDithers, Mode=OneWay}"/>
                                        <Run Text=" of "/>
                                        <Run Text="{Binding TotalDithers, Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Median settle (min–max) -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource MetricTileStyle}"
                                    Margin="0,0,4,0"
                                    ToolTip="Median settle time; caption shows the observed min–max range">
                                <StackPanel>
                                    <TextBlock Text="Median Settle"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding MedianSettleTime, StringFormat='{}{0:F2}s', Mode=OneWay}"
                                              Style="{StaticResource MetricValueStyle}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,2,0,0">
                                        <Run Text="{Binding MinSettleTime, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                                        <Run Text=" – "/>
                                        <Run Text="{Binding MaxSettleTime, StringFormat='{}{0:F2}s', Mode=OneWay}"/>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Drift (X / Y range) -->
                            <Border Grid.Column="3"
                                    Style="{StaticResource MetricTileStyle}"
                                    ToolTip="Range of the dither distribution along each axis (guide-camera pixels)">
                                <StackPanel>
                                    <TextBlock Text="Drift"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,2"/>
                                    <TextBlock Style="{StaticResource MetricValueStyle}"
                                              HorizontalAlignment="Center">
                                        <Run Text="{Binding TotalDriftX, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                                        <Run Text=" / "/>
                                        <Run Text="{Binding TotalDriftY, StringFormat='{}{0:F2}', Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="X / Y px"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Quality Metrics Panel - Shown when enough data -->
                <Border Style="{StaticResource SectionCardStyle}"
                       Visibility="{Binding ShowQualityAssessment, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                    <StackPanel>
                        <!-- Header with Overall Rating and EXPERIMENTAL Badge -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- Title with Experimental Badge -->
                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Dither Quality Assessment"
                                          Style="{StaticResource SectionHeaderStyle}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"/>

                                <!-- EXPERIMENTAL Badge -->
                                <Border Style="{StaticResource ExperimentalBadgeStyle}">
                                    <TextBlock Text="EXPERIMENTAL"
                                              Style="{StaticResource CaptionTextStyle}"
                                              FontWeight="Bold"
                                              VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <!-- Overall Rating Badge -->
                            <Border Grid.Column="1"
                                    Style="{StaticResource RatingBadgeStyle}"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="{Binding QualityResult.QualityRating, Mode=OneWay}"
                                              FontWeight="Bold"
                                              FontSize="11"
                                              Foreground="White"
                                              Margin="0,0,6,0"/>
                                    <TextBlock Text="{Binding CombinedScoreValue, Mode=OneWay}"
                                              FontSize="11"
                                              Foreground="White"
                                              Opacity="0.9"/>
                                </StackPanel>
                            </Border>

                            <!-- Toggle Button for Quality Assessment -->
                            <CheckBox Grid.Column="2"
                                     IsChecked="{Binding IsQualityAssessmentEnabled, Mode=TwoWay}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,5,0"
                                     ToolTip="Enable/Disable Quality Assessment"
                                     Style="{StaticResource ToggleSwitchStyle}"/>
                        </Grid>

                        <!-- Primary Metrics Grid -->
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Centered L2 Discrepancy -->
                            <Border Grid.Column="0"
                                    Style="{StaticResource MetricTileStyle}"
                                    Margin="0,0,4,0"
                                    ToolTip="Centered L₂ Discrepancy — how uniformly the sub-pixel dither offsets fill the sampling space. Lower is better (more even coverage).">
                                <StackPanel>
                                    <TextBlock Text="CD* · Uniformity"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding CDValue, Mode=OneWay}"
                                              Style="{StaticResource MetricValueStyle}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding CDRating, Mode=OneWay}"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- Drift Ratio (walking noise indicator) -->
                            <Border Grid.Column="1"
                                    Style="{StaticResource MetricTileStyle}"
                                    Margin="0,0,4,0"
                                    ToolTip="Drift ratio: net displacement / total path length. 0 = pattern returns to origin, 1 = one-directional drift (walking noise risk)">
                                <StackPanel>
                                    <TextBlock Text="Drift* · Walking noise"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding DriftValue, Mode=OneWay}"
                                              Style="{StaticResource MetricValueStyle}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding DriftRating, Mode=OneWay}"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>

                            <!-- NNI -->
                            <Border Grid.Column="2"
                                    Style="{StaticResource MetricTileStyle}"
                                    ToolTip="Nearest Neighbour Index — spacing regularity of the dither points. ≈1 random (ideal spread), &lt;1 clustered, &gt;1 over-regular grid.">
                                <StackPanel>
                                    <TextBlock Text="NNI* · Spacing"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,0,0,2"/>
                                    <TextBlock Text="{Binding NNIValue, Mode=OneWay}"
                                              Style="{StaticResource MetricValueStyle}"
                                              HorizontalAlignment="Center"/>
                                    <TextBlock Text="{Binding NNIRating, Mode=OneWay}"
                                              Style="{StaticResource SecondaryTextStyle}"
                                              HorizontalAlignment="Center"
                                              Margin="0,2,0,0"/>
                                </StackPanel>
                            </Border>
                        </Grid>

                        <!-- Drizzle Gap-Fill Metrics -->
                        <StackPanel Margin="0,0,0,10">
                            <TextBlock Text="Drizzle Coverage Uniformity (min/mean weight per output pixel)"
                                      Style="{StaticResource SecondaryTextStyle}"
                                      FontWeight="SemiBold"
                                      Margin="0,0,0,6"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- 1x Drizzle -->
                                <Border Grid.Column="0"
                                        Style="{StaticResource MetricTileStyle}"
                                        Margin="0,0,4,0">
                                    <StackPanel>
                                        <TextBlock Text="1× Drizzle"
                                                  Style="{StaticResource SecondaryTextStyle}"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding GFM1xValue, Mode=OneWay}"
                                                  Style="{StaticResource MetricValueStyle}"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding GFM1xTarget, Mode=OneWay}"
                                                  Style="{StaticResource SecondaryTextStyle}"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 2x Drizzle -->
                                <Border Grid.Column="1"
                                        Style="{StaticResource MetricTileStyle}"
                                        Margin="0,0,4,0">
                                    <StackPanel>
                                        <TextBlock Text="2× Drizzle"
                                                  Style="{StaticResource SecondaryTextStyle}"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding GFM2xValue, Mode=OneWay}"
                                                  Style="{StaticResource MetricValueStyle}"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding GFM2xTarget, Mode=OneWay}"
                                                  Style="{StaticResource SecondaryTextStyle}"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- 3x Drizzle -->
                                <Border Grid.Column="2"
                                        Style="{StaticResource MetricTileStyle}">
                                    <StackPanel>
                                        <TextBlock Text="3× Drizzle"
                                                  Style="{StaticResource SecondaryTextStyle}"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding GFM3xValue, Mode=OneWay}"
                                                  Style="{StaticResource MetricValueStyle}"
                                                  HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding GFM3xTarget, Mode=OneWay}"
                                                  Style="{StaticResource SecondaryTextStyle}"
                                                  HorizontalAlignment="Center"
                                                  Margin="0,2,0,0"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>

                        <!-- Recommendation -->
                        <Border Style="{StaticResource MetricTileStyle}"
                                Padding="10"
                                Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Recommendation"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          FontWeight="SemiBold"
                                          Margin="0,0,0,4"/>
                                <TextBlock Text="{Binding QualityResult.Recommendation, Mode=OneWay}"
                                          Style="{StaticResource CaptionTextStyle}"
                                          TextWrapping="Wrap"
                                          LineHeight="14"/>
                            </StackPanel>
                        </Border>

                        <!-- Derived scale-ratio context for the px-ratio parameter below. -->
                        <TextBlock Text="{Binding EffectiveScaleRatioText, Mode=OneWay}"
                                  Style="{StaticResource SecondaryTextStyle}"
                                  TextWrapping="Wrap"
                                  Margin="2,0,0,8"/>

                        <!-- Bottom row: sample-size note on the left; the pixfrac / px-ratio
                             parameters and the Recalc / Export Report actions grouped on the
                             right (these inputs are settings, not data, so they live with the
                             buttons rather than in the metrics area). -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                      VerticalAlignment="Center"
                                      Margin="2,0,0,0">
                                <Run Text="Based on"
                                     Foreground="{DynamicResource ButtonForegroundDisabledBrush}"
                                     FontSize="10"
                                     FontWeight="SemiBold"/>
                                <Run Text=" "/>
                                <Run Text="{Binding QualityResult.TotalDithers, StringFormat='{}{0} dithers', Mode=OneWay}"
                                     Foreground="{DynamicResource ButtonForegroundDisabledBrush}"
                                     FontSize="10"
                                     FontWeight="SemiBold"/>
                            </TextBlock>

                            <StackPanel Grid.Column="1"
                                       Orientation="Horizontal"
                                       VerticalAlignment="Center">
                                <!-- Parameters -->
                                <TextBlock Text="pixfrac"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,4,0"/>
                                <TextBox Text="{Binding QualityPixfrac, StringFormat=F2}"
                                         Width="36"
                                         FontSize="10"
                                         VerticalAlignment="Center"
                                         Margin="0,0,10,0"
                                         ToolTip="Drizzle pixfrac used for the coverage simulation (0-1, default 0.6)"/>
                                <TextBlock Text="px ratio"
                                          Style="{StaticResource SecondaryTextStyle}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,4,0"/>
                                <TextBox Text="{Binding PixelScaleRatioOverride, StringFormat=F2}"
                                         Width="36"
                                         FontSize="10"
                                         VerticalAlignment="Center"
                                         Margin="0,0,12,0"
                                         ToolTip="Main-camera pixels per guide-camera pixel. 0 = derive automatically from PHD2 pixel scale and the NINA profile (camera pixel size / focal length)"/>

                                <!-- Actions -->
                                <Button Content="Recalc"
                                        Tag="{StaticResource IconRefreshGeometry}"
                                        Command="{Binding RecalculateMetricsCommand}"
                                        Style="{StaticResource IconTextButtonStyle}"
                                        Margin="0,0,4,0"
                                        ToolTip="Recalculate quality metrics"/>

                                <Button Content="Export Report"
                                        Tag="{StaticResource IconExportGeometry}"
                                        Command="{Binding ExportMetricsCommand}"
                                        Style="{StaticResource IconTextButtonStyle}"
                                        ToolTip="Export detailed report (TXT)"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Info Box when Quality Assessment is disabled or not enough dithers.
                     Shares SectionStatusCardTemplate with the Optimizer info box. -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <!-- Show when Quality Assessment is disabled OR when enabled but not enough data -->
                                <DataTrigger Binding="{Binding ShowQualityAssessment, Mode=OneWay}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ContentControl Content="{Binding QualityStatus}"
                                    ContentTemplate="{StaticResource SectionStatusCardTemplate}"/>
                </Border>

                <!-- Dither Settings Optimizer Panel - Shown when enabled and enough data -->
                <Border Style="{StaticResource SectionCardStyle}"
                       Visibility="{Binding ShowDitherOptimizer, Converter={StaticResource BoolToVis}, Mode=OneWay}">
                    <StackPanel>
                        <!-- Header with EXPERIMENTAL Badge and Toggle -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Dither Settings Optimizer"
                                          Style="{StaticResource SectionHeaderStyle}"
                                          VerticalAlignment="Center"
                                          Margin="0,0,8,0"/>
                                <Border Style="{StaticResource ExperimentalBadgeStyle}">
                                    <TextBlock Text="EXPERIMENTAL"
                                              Style="{StaticResource CaptionTextStyle}"
                                              FontWeight="Bold"
                                              VerticalAlignment="Center"/>
                                </Border>
                            </StackPanel>

                            <CheckBox Grid.Column="1"
                                     IsChecked="{Binding IsDitherOptimizerEnabled, Mode=TwoWay}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,5,0"
                                     ToolTip="Enable/Disable Dither Settings Optimizer"
                                     Style="{StaticResource ToggleSwitchStyle}"/>
                        </Grid>

                        <!-- Strict (P90) / Standard (P95) / Fast (P99) rendered from a
                             single template over the OptimizerProfiles collection; the
                             Fast column carries the accent border (Step 6). -->
                        <ItemsControl ItemsSource="{Binding OptimizerProfiles}"
                                      ItemTemplate="{StaticResource OptimizerProfileTemplate}"
                                      Margin="0,0,0,10">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <UniformGrid Columns="3"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>

                        <!-- Footer info -->
                        <TextBlock Text="{Binding RecommendationInfo, Mode=OneWay}"
                                  Style="{StaticResource SecondaryTextStyle}"
                                  HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding RecommendationWarning, Mode=OneWay}"
                                  FontSize="10"
                                  Foreground="Orange"
                                  TextWrapping="Wrap"
                                  HorizontalAlignment="Center"
                                  Margin="0,4,0,0"
                                  Visibility="{Binding HasRecommendationWarning, Converter={StaticResource BoolToVis}, Mode=OneWay}"/>
                    </StackPanel>
                </Border>

                <!-- Info Box when Dither Optimizer is disabled or not enough data.
                     Shares SectionStatusCardTemplate with the Quality info box. -->
                <Border>
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowDitherOptimizer, Mode=OneWay}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <ContentControl Content="{Binding OptimizerStatus}"
                                    ContentTemplate="{StaticResource SectionStatusCardTemplate}"/>
                </Border>

                <!-- Actions toolbar: slim, no header, right-aligned - folds the former
                     standalone "Actions" card into a single low-weight row (Step 7). -->
                <Border Style="{StaticResource SectionCardStyle}">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Clear Data"
                               Tag="{StaticResource IconDeleteGeometry}"
                               Command="{Binding ClearDataCommand}"
                               Style="{StaticResource IconTextButtonStyle}"
                               Margin="0,0,4,0"
                               ToolTip="Clear all statistics for the active profile"/>

                        <Button Content="Export Events CSV"
                               Tag="{StaticResource IconExportGeometry}"
                               Command="{Binding ExportDitherEventsCsvCommand}"
                               Style="{StaticResource IconTextButtonStyle}"
                               ToolTip="Export dither events to CSV (timestamps, pixel shifts, settle times)"/>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
